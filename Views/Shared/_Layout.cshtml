<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExcelCRUD</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        /* ═══════════════════════════════════════════════
           SIDEBAR LAYOUT
        ═══════════════════════════════════════════════ */
        .app-shell {
            display: flex;
            min-height: 100vh;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 230px;
            background: rgba(8, 13, 24, 0.97);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(99, 140, 255, 0.12);
            display: flex;
            flex-direction: column;
            padding: 24px 0 20px;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 200;
        }

        /* Brand */
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 18px 22px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            margin-bottom: 14px;
            text-decoration: none;
        }

        .brand-icon {
            width: 38px; height: 38px;
            border-radius: 11px;
            background: linear-gradient(135deg, #4f7eff, #2563eb);
            display: grid; place-items: center;
            font-size: 17px;
            color: #fff;
            flex-shrink: 0;
            box-shadow: 0 0 18px rgba(79,126,255,0.35);
        }

        .brand-name {
            font-family: 'Syne', sans-serif;
            font-size: 17px;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.3px;
        }

        /* Section Label */
        .sidebar-section {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.8px;
            text-transform: uppercase;
            color: #6b7fa8;
            padding: 0 18px;
            margin: 10px 0 4px;
        }

        /* Nav Links */
        .sidebar-nav {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .sidebar-nav a {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 11px 18px;
            margin: 1px 10px;
            border-radius: 10px;
            color: #6b7fa8;
            font-size: 13.5px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s ease;
            position: relative;
        }

        .sidebar-nav a i {
            font-size: 14px;
            width: 18px;
            text-align: center;
        }

        .sidebar-nav a:hover {
            background: rgba(79,126,255,0.08);
            color: #a8bfff;
        }

        .sidebar-nav a.active {
            background: rgba(79,126,255,0.14);
            color: #fff;
            font-weight: 600;
        }

        .sidebar-nav a.active i {
            color: #4f7eff;
        }

        .sidebar-nav a.active::before {
            content: '';
            position: absolute;
            left: -10px;
            top: 50%; transform: translateY(-50%);
            width: 3px; height: 22px;
            background: #4f7eff;
            border-radius: 0 3px 3px 0;
        }

        /* Storage badge */
        .sidebar-footer {
            padding: 14px 18px 0;
            border-top: 1px solid rgba(255,255,255,0.06);
            margin-top: 10px;
        }

        .storage-badge {
            display: flex;
            align-items: center;
            gap: 9px;
            background: rgba(16,185,129,0.08);
            border: 1px solid rgba(16,185,129,0.18);
            border-radius: 10px;
            padding: 10px 13px;
        }

        .storage-badge i {
            color: #10b981;
            font-size: 14px;
        }

        .storage-badge span {
            font-size: 12px;
            font-weight: 600;
            color: #10b981;
        }

        .storage-badge small {
            display: block;
            font-size: 10.5px;
            color: #6b7fa8;
            font-weight: 400;
        }

        /* ── Main Content ── */
        .main-content {
            margin-left: 230px;
            flex: 1;
            min-width: 0;
        }

        /* ── Mobile Toggle ── */
        .mobile-toggle {
            display: none;
            position: fixed;
            top: 14px; left: 14px;
            z-index: 300;
            width: 40px; height: 40px;
            border-radius: 10px;
            background: rgba(12,19,38,0.95);
            border: 1px solid rgba(99,140,255,0.2);
            color: #dce8ff;
            font-size: 16px;
            cursor: pointer;
            place-items: center;
        }

        .sidebar-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(3px);
            z-index: 150;
        }
    </style>
</head>
<body>

<div class="app-shell">

    <!-- ══ SIDEBAR ══ -->
    <aside class="sidebar" id="sidebar">

        <!-- Brand -->
        <a href="@Url.Action("Index", "Student")" class="sidebar-brand">
            <div class="brand-icon"><i class="fa-solid fa-graduation-cap"></i></div>
            <span class="brand-name">ExcelCRUD</span>
        </a>

        <!-- Nav -->
        <nav class="sidebar-nav">
            <div class="sidebar-section">Main Menu</div>

            <a href="@Url.Action("Index", "Student")"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <i class="fa-solid fa-users"></i>
                Students
            </a>

            <a href="@Url.Action("ImportExcel", "Student")"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ImportExcel" ? "active" : "")">
                <i class="fa-solid fa-file-import"></i>
                Import Excel
            </a>

            <a href="@Url.Action("ExportExcel", "Student")"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ExportExcel" ? "active" : "")">
                <i class="fa-solid fa-file-export"></i>
                Export Excel
            </a>
        </nav>

        <!-- Footer -->
        <div class="sidebar-footer">
            <div class="storage-badge">
                <i class="fa-solid fa-database"></i>
                <div>
                    <span>Excel Storage</span>
                    <small>students.xlsx</small>
                </div>
            </div>
        </div>

    </aside>

    <!-- Backdrop (mobile) -->
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="closeSidebar()"></div>

    <!-- Mobile toggle button -->
    <button class="mobile-toggle" onclick="toggleSidebar()">
        <i class="fa-solid fa-bars"></i>
    </button>

    <!-- ══ MAIN CONTENT ══ -->
    <main class="main-content">
        @RenderBody()
    </main>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function toggleSidebar() {
        document.getElementById('sidebar').classList.toggle('open');
        document.getElementById('sidebarBackdrop').classList.toggle('open');
    }
    function closeSidebar() {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('sidebarBackdrop').classList.remove('open');
    }
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>